# PostgreSQL 16 (Prisma). Пример: postgresql://user:password@localhost:5432/imbir
DATABASE_URL=

# Auth.js (админка) — сгенерировать: npx auth secret
AUTH_SECRET=

# Ключ AES-256 для одноразового показа кода сертификата (64 hex-символа):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CODE_ENCRYPTION_KEY=

# Демо-оплата для разработки/тестов (НЕ включать в production)
PAYMENT_MOCK=

# Отключение обязательной 2FA (TOTP) в админке — ТОЛЬКО локальная разработка.
# В production игнорируется (NODE_ENV=production) и не должно ставиться.
ADMIN_2FA_DISABLED=

# Платёжные провайдеры (Фаза 1)
KASPI_PAY_MERCHANT_ID=
KASPI_PAY_SECRET=
FREEDOM_PAY_MERCHANT_ID=
FREEDOM_PAY_SECRET=

# Email (Resend); без ключа письма пишутся в .mail-outbox/ (dev-мок)
RESEND_API_KEY=
MAIL_FROM=
MANAGER_EMAIL=

# WhatsApp через ChatApp (chatapp.online). Без полного набора секретов
# сообщения пишутся в .wa-outbox/ (dev-мок). WHATSAPP_MOCK=1 форсит мок.
CHATAPP_EMAIL=
CHATAPP_PASSWORD=
CHATAPP_APP_ID=
CHATAPP_LICENSE_ID=      # узнать через GET /v1/licenses (напр. 45740)
# messenger type: для «[WEB] WhatsApp» в ChatApp это grWhatsApp,
# для официального WhatsApp Business API — whatsapp
CHATAPP_MESSENGER=grWhatsApp
WHATSAPP_MOCK=

# Публичный URL сайта (QR-ссылки, ссылки в письмах)
SITE_URL=

# Altegio (Фаза 3) — запись продаж сертификатов в CRM.
# Для полного синка нужны partner_token + user_token + location_id филиалов.
ALTEGIO_PARTNER_TOKEN=
ALTEGIO_USER_TOKEN=
ALTEGIO_API_KEY=

# Sentry
SENTRY_DSN=
